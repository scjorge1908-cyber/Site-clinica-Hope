rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == 'scjorge1908@gmail.com';
    }

    // Allow public read on all collections
    match /specialists/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /approaches/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /insurance_plans/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

